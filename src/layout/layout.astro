---
import { theme } from '../theme';
import { is_post } from '@src/utils';
import { bgImgUrl } from '../config.js';
import Head from './head.astro';
import HeaderIndex from './header/index.astro';
import Footer from './footer.astro';
import Sidebar from './sidebar.astro';
import LoadingIndex from './loadings/index.astro';
import WidgetIndex from './widget/index.astro';
import AdditionalJs from './additional-js.astro';
import Rightside from './rightside.astro';

// ✅ 完整规范的TS接口定义，替换原残缺接口
interface Props {
  lang: string;
  page: Record<string, any>;
  postHeadings?: Array<{
    depth: number;
    slug: string;
    text: string;
  }>;
}

// ✅ 解构Props并指定类型，彻底消除所有解构警告
const { lang, page, postHeadings } = Astro.props as Props;
const isPost = is_post(Astro.url);

// ✅ 背景图核心方法 + 完整TS类型注解 + 健壮性兜底
const getBgPath = (bg: string | null | undefined): string => {
  if (!bg || typeof bg !== 'string') return '';
  return `background: url(${bg}) no-repeat center center; background-size: cover; background-attachment: fixed;`;
};
---

<html lang={lang} data-theme={theme.display_mode || 'light'} class={`${theme.aside?.enable && theme.aside?.hide ? 'hide-aside' : ''}`}>
  <Head lang={lang} page={page} />
  <body>
    <LoadingIndex />

    <!-- 背景图容器 - 完美生效+容错 -->
    {bgImgUrl && (
      <div id="web_bg" style={getBgPath(bgImgUrl)}></div>
    )}

    <Sidebar lang={lang} />
    <div id="body-wrap" class={`${isPost ? 'post' : 'page'}${page.type ? ' type-' + page.type : ''}`}>
      <HeaderIndex lang={lang} page={page} />
      <main class='layout' id="content-inner">
        <slot />
        <WidgetIndex lang={lang} postHeadings={postHeadings} />
      </main>
      <Footer lang={lang} />
    </div>
    <Rightside lang={lang} />
    <AdditionalJs />
  </body>
</html>
