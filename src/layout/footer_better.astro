---
/**
 * Converted from footer_better.pug
 * Props:
 *  - theme: same structure as original pug expects
 */
import '../source/css/_footer/footer_better.styl'; // <- 导入 Stylus 文件（项目根路径）

const { theme = {} } = Astro.props;

const now = new Date();
const nowYear = now.getFullYear();

const footerIcons = (theme?.footer_better?.footer_icons) || {};
const footerGroup = (theme?.footer_better?.footer_group) || {};
const footerBottom = (theme?.footer_better?.footer_bottom) || {};

const friendLinksCfg = footerGroup?.footer_friend_links || {};
const friendLinks = Array.isArray(friendLinksCfg.links) ? friendLinksCfg.links : [];
const showNum = typeof friendLinksCfg.number === 'number' ? friendLinksCfg.number : 5;

/** Utility: shallow shuffle for initial random selection */
function shuffleArray(arr) {
  return [...arr].sort(() => Math.random() - 0.5);
}
const randomLinks = friendLinks.length > 0 ? shuffleArray(friendLinks).slice(0, showNum) : [];
---
<div id="footer-wrap" style="background: transparent">
  <!-- 1. 底部图标区 -->
  {footerIcons.enable && (
    <div id="footer_icons">
      <div>
        {(footerIcons.left || []).map((i, idx) => {
          const isIn = i.class === 'in';
          const isOut = i.class === 'out';
          const commonProps = { href: i.link, title: i.desrc };
          if (isIn) {
            // 内链
            return theme?.pjax?.enable ? (
              <a class="icon_link" {...commonProps} data-pjax-state key={idx}><i class={i.icon}></i></a>
            ) : (
              <a class="icon_link" {...commonProps} key={idx}><i class={i.icon}></i></a>
            );
          } else if (isOut) {
            // 外链
            return (
              <a class="icon_link" rel="noopener external nofollow" href={i.link} title={i.desrc} target="_blank" key={idx}>
                <i class={i.icon}></i>
              </a>
            );
          } else {
            return (
              <a class="icon_link" href={i.link} title={i.desrc} key={idx}>
                <i class={i.icon}></i>
              </a>
            );
          }
        })}
      </div>

      {footerIcons.footer_logo?.enable && (
        <div class="footer_logo_container" onclick="btf.scrollToDest(0,500)" title="返回顶部">
          <img class="footer_logo" src={footerIcons.footer_logo.url} alt="footer-logo" />
        </div>
      )}

      <div>
        {(footerIcons.right || []).map((i, idx) => {
          const isIn = i.class === 'in';
          const isOut = i.class === 'out';
          if (isIn) {
            return theme?.pjax?.enable ? (
              <a class="icon_link" href={i.link} title={i.desrc} data-pjax-state key={idx}><i class={i.icon}></i></a>
            ) : (
              <a class="icon_link" href={i.link} title={i.desrc} key={idx}><i class={i.icon}></i></a>
            );
          } else if (isOut) {
            return (
              <a class="icon_link" rel="noopener external nofollow" href={i.link} title={i.desrc} target="_blank" key={idx}>
                <i class={i.icon}></i>
              </a>
            );
          } else {
            return (
              <a class="icon_link" href={i.link} title={i.desrc} key={idx}><i class={i.icon}></i></a>
            );
          }
        })}
      </div>
    </div>
  )}

  <!-- 2. 底部分组链接区（修复嵌套问题） -->
  {footerGroup.enable && (
    <div id="footer_content">
      {(footerGroup.footer_group_link || []).map((item, gi) => (
        <div class="footer-group" key={gi}>
          <h3 class="footer-title">{item.group_title}</h3>
          <div class="footer-links">
            {(item.footer_links || []).map((i, li) => {
              if (i.class === 'in') {
                return theme?.pjax?.enable ? (
                  <a class="footer-item" href={i.link} data-pjax-state key={li}>{i.text}</a>
                ) : (
                  <a class="footer-item" href={i.link} key={li}>{i.text}</a>
                );
              } else if (i.class === 'out') {
                return (
                  <a class="footer-item" target="_blank" href={i.link} key={li}>{i.text}</a>
                );
              } else {
                return (
                  <a class="footer-item" href={i.link} key={li}>{i.text}</a>
                );
              }
            })}
          </div>
        </div>
      ))}

      {/* 友链区域：独立分组 */}
      {footerGroup.footer_friend_links?.enable && (
        <div class="footer-group" id="friend-links-in-footer">
          <h3 class="footer-title">
            友链
            <button title="换一批" href="javascript:;" id="refresh-friend-link" style="margin-left:8px; border:none; background:transparent; cursor:pointer;">
              <i class="fa-solid fa-rotate-right"></i>
            </button>
          </h3>
          <div class="footer-links">
            <div id="friend-links-list" data-all-links={JSON.stringify(friendLinks)} data-show-num={showNum}>
              {randomLinks.map((link, idx) => (
                <a class="footer-item" target="_blank" href={link.url} key={idx}>{link.name}</a>
              ))}
            </div>
            <a class="footer-item" href="/links/" data-pjax-state> 查看更多</a>
          </div>
        </div>
      )}
    </div>
  )}

  <!-- 3. 底部版权/运行信息区 -->
  <div id="footer-bottom">
    <div class="footer-bottom-content">
      <div class="footer-bottom-left">
        {footerBottom?.copyright?.enable && (() => {
          const since = footerBottom?.copyright?.since;
          const link = footerBottom?.copyright?.link;
          const author = footerBottom?.copyright?.author;
          if (since && String(since) !== String(nowYear)) {
            return (
              <span class="copyright">
                <span dangerouslySetInnerHTML={{ __html: `&copy;${since} - ${nowYear} By ` }}></span>
                <a target="_blank" rel="noopener" href={link} title={`点击访问"${author}"的主页`} style="margin-left:5px">{author}</a>
              </span>
            );
          } else {
            return (
              <span class="copyright">
                <span dangerouslySetInnerHTML={{ __html: `&copy;${nowYear} By ` }}></span>
                <a target="_blank" rel="noopener" href={link} title={`点击访问"${author}"的主页`} style="margin-left:5px">{author}</a>
              </span>
            );
          }
        })()}

        <div>
          {(footerBottom?.left || []).length > 0 && (footerBottom.left || []).map((i, idx) => (
            <a class="footer-bottom-link" target="_blank" href={i.link} rel="noopener external nofollow" title={i.desrc} key={idx}>{i.text}</a>
          ))}
        </div>
      </div>

      <div class="footer-bottom-right">
        {footerBottom?.runtime?.enable && (
          <div id="runtime" title="本站运行时间">本站已苟活：0 天 0 时 0 分 0 秒</div>
        )}
        <div>
          {(footerBottom?.right || []).length > 0 && (footerBottom.right || []).map((i, idx) => (
            <a class="footer-bottom-link" target="_blank" href={i.link} rel="noopener external nofollow" title={i.desrc} key={idx}>{i.text}</a>
          ))}
        </div>
      </div>
    </div>
  </div>
</div>

<!-- 客户端脚本：友链随机刷新（等同于 include ./randomlink.pug 的功能） -->
<script type="module">
  // 当页面在客户端加载时，设置换一批功能
  const refreshBtn = document.getElementById('refresh-friend-link');
  const friendListEl = document.getElementById('friend-links-list');
  if (refreshBtn && friendListEl) {
    refreshBtn.addEventListener('click', () => {
      try {
        const allLinks = JSON.parse(friendListEl.getAttribute('data-all-links') || '[]');
        const showNum = parseInt(friendListEl.getAttribute('data-show-num') || '5', 10);
        if (!Array.isArray(allLinks) || allLinks.length === 0) return;
        const shuffled = allLinks.sort(() => Math.random() - 0.5).slice(0, showNum);
        // 清空并重新渲染
        friendListEl.innerHTML = '';
        shuffled.forEach(link => {
          const a = document.createElement('a');
          a.className = 'footer-item';
          a.target = '_blank';
          a.href = link.url;
          a.textContent = link.name;
          friendListEl.appendChild(a);
        });
      } catch (e) {
        console.error('刷新友链失败', e);
      }
    });
  }
</script>