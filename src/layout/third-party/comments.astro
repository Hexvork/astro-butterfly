---
const { lang } = Astro.props;
import { useTranslations } from '@src/utils';
const t = useTranslations(lang);
---

<hr class="custom-hr" />
<div id="post-comment">
  <div class="comment-head">
    <div class="comment-headline">
      <i class="fas fa-comments fa-fw"></i>
      <span>{' ' + t('comment')}</span>
    </div>
  </div>

  <div class="comment-wrap">
    <div id="artalk-container" style="width: 100%;"></div>
  </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdmirror.com/npm/artalk@2.9.1/dist/Artalk.min.css" />
<script src="https://cdn.jsdmirror.com/npm/artalk@2.9.1/dist/Artalk.min.js"></script>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const pathname = window.location.pathname;
  const artalkLocale = '${lang}' === 'en' ? 'en-US' : 'zh-CN';

  const artalkInstance = Artalk.init({
    el: '#artalk-container',
    server: '/artalk-api',         // 本地代理（线上改 https://artalk.yuyano.com）
    site: 'Weston-Blog',           // 与Artalk后台站点标识一致
    locale: artalkLocale,          // 最终生效的多语言配置
    pageKey: pathname,             // 路由隔离不同文章评论
    pageTitle: document.title,
    placeholder: artalkLocale === 'zh-CN' ? '写下你的评论吧～' : 'Write your comment...'
  });

  if (window.btf) {
    btf.addGlobalFn('pjaxComplete', () => artalkInstance.reload(), 'artalkReload');
  }
});
</script>
