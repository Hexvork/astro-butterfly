---
import { getConfig } from '../config';
import '../source/css/_layout/footer.styl';

interface LinkItem {
  text?: string;
  name?: string;
  link?: string;
  url?: string;
  class?: string;
  desc?: string;
  icon?: string;
}

interface CopyrightInfo {
  author?: string;
  link?: string;
  since?: number;
}

interface TimeUnits {
  days?: string;
  hours?: string;
  minutes?: string;
  seconds?: string;
}

interface FooterText {
  friend_link_title?: string;
  refresh_link_btn?: string;
  view_more_links?: string;
  runtime_prefix?: string;
  back_to_top?: string;
  icp_title?: string;
  github_source_title?: string;
  cloudflare_cdn_title?: string;
  astro_frame_title?: string;
  butterfly_theme_title?: string;
  time_units?: TimeUnits;
}

interface FooterBetter {
  footer_icons?: {
    left?: LinkItem[];
    right?: LinkItem[];
    footer_logo?: { url?: string };
  };
  footer_bottom?: {
    copyright?: CopyrightInfo;
  };
  footer_group?: {
    footer_friend_links?: { links: LinkItem[]; number: number };
    footer_group_link?: { group_title?: string; footer_links: LinkItem[] }[];
  };
}

interface ThemeConfig {
  author?: string;
  footer_better?: FooterBetter;
  footer_text?: FooterText;
  [key: string]: any;
}

const currentPath = Astro.url.pathname;
const lang = currentPath.startsWith('/en/') ? 'en' : 'zh-CN';
const theme: ThemeConfig = getConfig(lang);
const cfg = theme.footer_better || {};
const footerText = theme.footer_text || {};
const timeUnits = footerText.time_units || { days: '天', hours: '时', minutes: '分', seconds: '秒' };

const calcRuntime = (): string => {
  const startTime = new Date(2025, 0, 1);
  const diff = Date.now() - startTime.getTime();
  const days = Math.floor(diff / (1000 * 60 * 60 * 24));
  const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
  const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
  const seconds = Math.floor((diff % (1000 * 60)) / 1000);
  return `${footerText.runtime_prefix || '本站已苟活：'}${days} ${timeUnits.days} ${hours} ${timeUnits.hours} ${minutes} ${timeUnits.minutes} ${seconds} ${timeUnits.seconds}`;
};

const friendLinks = cfg.footer_group?.footer_friend_links?.links || [];
const showNum = cfg.footer_group?.footer_friend_links?.number || 5;
const randomLinks = friendLinks.length 
  ? friendLinks.sort(() => Math.random() - 0.5).slice(0, showNum) 
  : [];

const now = new Date();
const nowYear = now.getFullYear();
const copyInfo = cfg.footer_bottom?.copyright || {};
const author = copyInfo.author || theme.author || 'Weston Brown';
const copySince = copyInfo.since || 2025;

const icons = cfg.footer_icons || {};
const iconLeft = icons.left || [];
const iconRight = icons.right || [];
const logoUrl = icons.footer_logo?.url || '';

const groupLinks = cfg.footer_group?.footer_group_link || [];
---

<footer id="footer-wrap" 
  data-runtime-prefix={footerText.runtime_prefix}
  data-time-units={JSON.stringify(timeUnits)}
>
  <div 
    id="footer_icons" 
    style="display: flex; justify-content: center; align-items: center; margin-bottom: 20px; padding: 10px 0; border-bottom: none !important; gap: 20px;"
  >
    <div style="display: flex; gap: 6px;">
      {iconLeft.map((item: LinkItem, index: number) => (
        <a
          data-key={index}
          class="icon_link"
          href={item.link || '#'}
          title={item.desc || ''}
          rel={item.class === 'out' ? 'noopener external nofollow' : ''}
          target={item.class === 'out' ? '_blank' : '_self'}
          style="display: inline-block;"
        >
          <i class={item.icon}></i>
        </a>
      ))}
    </div>

    {logoUrl ? (
      <div 
        class="footer_logo_container" 
        title={footerText.back_to_top || '返回顶部'} 
        onclick="window.scrollTo({top: 0, behavior: 'smooth'})"
      >
        <img 
          class="footer_logo" 
          src={logoUrl} 
          style="width: auto; height: 40px; object-fit: contain;" 
          alt={footerText.back_to_top || '返回顶部'} 
        />
      </div>
    ) : null}

    <div style="display: flex; gap: 6px;">
      {iconRight.map((item: LinkItem, index: number) => (
        <a
          data-key={index}
          class="icon_link"
          href={item.link || '#'}
          title={item.desc || ''}
          rel={item.class === 'out' ? 'noopener external nofollow' : ''}
          target={item.class === 'out' ? '_blank' : '_self'}
          style="display: inline-block;"
        >
          <i class={item.icon}></i>
        </a>
      ))}
    </div>
  </div>

  <div 
    id="footer_content" 
    style="display: flex; flex-wrap: wrap; justify-content: space-between; margin-bottom: 20px; gap: 20px; padding: 0 5px;"
  >
    {groupLinks.map((group: any, index: number) => (
      <div data-key={index} class="footer-group" style="min-width: 140px;">
        <h3 class="footer-title">{group.group_title}</h3>
        <div class="footer-links" style="display: flex; flex-direction: column; gap: 4px;">
          {group.footer_links.map((item: LinkItem, idx: number) => (
            <a
              data-key={idx}
              class="footer-item"
              href={item.link || '#'}
              target={item.class === 'out' ? '_blank' : '_self'}
              style="display: block;"
            >
              {item.text}
            </a>
          ))}
        </div>
      </div>
    ))}

    <div class="footer-group" style="min-width: 140px;">
      <h3 class="footer-title">
        {footerText.friend_link_title || '友链'}
        <button 
          title={footerText.refresh_link_btn || '换一批'} 
          id="refresh-friend-link" 
          style="margin-left:6px; border:none; background:transparent; cursor:pointer;"
        >
          <i class="fa-solid fa-rotate-right"></i>
        </button>
      </h3>
      <div class="footer-links" style="display: flex; flex-direction: column; gap: 4px;">
        <div 
          id="friend-links-list" 
          data-all-links={JSON.stringify(friendLinks)} 
          data-show-num={showNum}
        >
          {randomLinks.map((link: LinkItem, idx: number) => (
            <a
              data-key={idx}
              class="footer-item"
              target="_blank"
              href={link.url || '#'}
              style="display: block;"
            >
              {link.name}
            </a>
          ))}
        </div>
        <a class="footer-item" href={`/${lang}/links/`} data-pjax-state style="display: block;">{footerText.view_more_links || '查看更多'}</a>
      </div>
    </div>
  </div>

  <div 
    id="footer-bottom" 
    style="display: flex; flex-wrap: wrap; justify-content: space-between; padding: 15px 5px; border-top: none !important;"
  >
    <div class="footer-bottom-left" style="display: flex; flex-direction: column; gap: 4px; min-width: 280px;">
      <span class="copyright" style="display: block; font-size: 14px;">
        {copySince !== nowYear ? `©${copySince} - ${nowYear} By ${author}` : `©${nowYear} By ${author}`}
      </span>
      <div style="display: flex; align-items: center; gap: 8px; flex-wrap: wrap;">
        <a 
          href="https://icp.gov.moe/?keyword=20251308" 
          title={footerText.icp_title || '萌ICP备20251308号'} 
          target="_blank" 
          style="display: inline-block;"
        >
          <img src="/img/0/Footer-icp-Moeicp.svg" style="width: auto; height: auto;" alt={footerText.icp_title || '萌ICP备20251308号'} />
        </a>
        <a 
          href="https://github.com" 
          title={footerText.github_source_title || 'Github源码托管'} 
          target="_blank" 
          style="display: inline-block;"
        >
          <img src="/img/0/Footer-Source-Github.svg" style="width: auto; height: auto;" alt="Github" />
        </a>
        <a 
          href="https://Cloudflare-cn.com/" 
          title={footerText.cloudflare_cdn_title || 'Cloudflare CDN加速'} 
          target="_blank" 
          style="display: inline-block;"
        >
          <img src="/img/0/Footer-CDN-Cloudflare.svg" style="width: auto; height: auto;" alt="Cloudflare" />
        </a>
      </div>
    </div>

    <div class="footer-bottom-right" style="display: flex; flex-direction: column; gap: 4px; text-align: right; min-width: 280px;">
      <div id="runtime" style="font-size: 14px; display: block;">{calcRuntime()}</div>
      <div style="display: flex; align-items: center; gap: 8px; justify-content: flex-end; flex-wrap: wrap;">
        <a 
          href="https://astro.build" 
          title={footerText.astro_frame_title || 'Astro 静态站点框架'} 
          target="_blank" 
          style="display: inline-block;"
        >
          <img src="/img/0/Footer-Frame-Astro.svg" style="width: auto; height: auto;" alt="Astro" />
        </a>
        <a 
          href="https://butterfly.js.org" 
          title={footerText.butterfly_theme_title || 'Butterfly 主题'} 
          target="_blank" 
          style="display: inline-block;"
        >
          <img src="/img/0/Footer-Theme-Butterfly.svg" style="width: auto; height: auto;" alt="Butterfly" />
        </a>
      </div>
    </div>
  </div>
</footer>

<script is:inline>
  setInterval(() => {
    const startTime = new Date(2025, 0, 1);
    const diff = Date.now() - startTime.getTime();
    const days = Math.floor(diff / (1000 * 60 * 60 * 24));
    const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
    const seconds = Math.floor((diff % (1000 * 60)) / 1000);
    const footerWrap = document.getElementById('footer-wrap');
    const runtimePrefix = footerWrap?.dataset.runtimePrefix || '本站已苟活：';
    const timeUnits = footerWrap?.dataset.timeUnits ? JSON.parse(footerWrap.dataset.timeUnits) : {
      days: '天', hours: '时', minutes: '分', seconds: '秒'
    };
    const el = document.getElementById('runtime');
    if (el) el.textContent = `${runtimePrefix}${days} ${timeUnits.days} ${hours} ${timeUnits.hours} ${minutes} ${timeUnits.minutes} ${seconds} ${timeUnits.seconds}`;
  }, 1000);

  document.getElementById('refresh-friend-link')?.addEventListener('click', () => {
    const listEl = document.getElementById('friend-links-list');
    if (!listEl) return;
    const allLinks = JSON.parse(listEl.dataset.allLinks || '[]');
    const showNum = parseInt(listEl.dataset.showNum || '5');
    const randomLinks = allLinks.sort(() => Math.random() - 0.5).slice(0, showNum);
    listEl.innerHTML = randomLinks.map((link, idx) => `
      <a data-key="${idx}" class="footer-item" target="_blank" href="${link.url || '#'}" style="display: block;">${link.name}</a>
    `).join('');
  });
</script>
